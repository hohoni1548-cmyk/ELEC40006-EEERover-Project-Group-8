"</body></html>"
  ));
}

// ---------------- REQUEST HANDLING ----------------

void handleRequest(String requestLine, WiFiClient &client) {
  if (requestLine.startsWith("GET / ") || requestLine.startsWith("GET /?")) {
    sendWebpage(client);
  }
  else if (requestLine.startsWith("GET /forward")) {
    if (!acceptMovementCommand(requestLine)) {
      sendText(client, "STALE");
      return;
    }
    driveForward();
    sendText(client, "FWD");
  }
  else if (requestLine.startsWith("GET /backward")) {
    if (!acceptMovementCommand(requestLine)) {
      sendText(client, "STALE");
      return;
    }

    driveBackward();
    sendText(client, "BWD");
  }
  else if (requestLine.startsWith("GET /left")) {
    if (!acceptMovementCommand(requestLine)) {
      sendText(client, "STALE");
      return;
    }

    driveLeft();
    sendText(client, "L");
  }
  else if (requestLine.startsWith("GET /right")) {
    if (!acceptMovementCommand(requestLine)) {
      sendText(client, "STALE");
      return;
    }

    driveRight();
    sendText(client, "R");
  }
  else if (requestLine.startsWith("GET /fwdleft")) {
    if (!acceptMovementCommand(requestLine)) {
      sendText(client, "STALE");
      return;
    }

    driveForwardLeft();
    sendText(client, "FL");
  }
  else if (requestLine.startsWith("GET /fwdright")) {
    if (!acceptMovementCommand(requestLine)) {
      sendText(client, "STALE");
      return;
    }

    driveForwardRight();
    sendText(client, "FR");
  }
  else if (requestLine.startsWith("GET /backleft")) {
    if (!acceptMovementCommand(requestLine)) {
      sendText(client, "STALE");
      return;
    }

    driveBackLeft();
    sendText(client, "BL");
  }
  else if (requestLine.startsWith("GET /backright")) {
    if (!acceptMovementCommand(requestLine)) {
      sendText(client, "STALE");
      return;
    }

    driveBackRight();
    sendText(client, "BR");
  }
  else if (requestLine.startsWith("GET /stop")) {
    if (!acceptMovementCommand(requestLine)) {
      sendText(client, "STALE");
      return;
    }

    stopMotors();
    sendText(client, "STOP");
  }
  else if (requestLine.startsWith("GET /keepalive")) {
    if (acceptKeepAlive(requestLine)) {
      refreshMotorTimeout();
      sendText(client, "K");
    }
    else {
      sendText(client, "K_OLD");
    }
  }
  else if (requestLine.startsWith("GET /speed?level=0")) {
    speedMode = 0;
    sendText(client, "MIN");
  }
  else if (requestLine.startsWith("GET /speed?level=1")) {
    speedMode = 1;
    sendText(client, "MID");
  }
  else if (requestLine.startsWith("GET /speed?level=2")) {
    speedMode = 2;
    sendText(client, "MAX");
  }
  else if (requestLine.startsWith("GET /calibratemag")) {
    calibrateMagneticBaseline();

    String message = String(magneticBaselineZ);
    sendText(client, message.c_str());
  }
  else if (requestLine.startsWith("GET /inputs")) {
    sBmm150MagData_t magData = getMagneticData();
    String magDirection = getMagneticDirection(magData.z);
    updateLastValidMagnetic(magDirection);

    String magZText;
    if (!bmmReady) {
      magZText = "NO READING";
    }
    else {
      magZText = String(magData.z);
      magZText += " uT";
    }

    String irText;
    if (irPulseRate == 0) {
      irText = "NO READING";
    }
    else {
      irText = String(irPulseRate);
      irText += " pulses/sec";
    }

    String ultrasonicText;
    if (ultrasonicDetected) {
      ultrasonicText = "40kHz DETECTED";
    }
    else {
      ultrasonicText = "NO READING";
    }

    String message = magDirection;
    message += "|";
    message += magZText;
    message += "|";
    message += String(magneticBaselineZ);
    message += "|";
    message += irText;
    message += "|";
    message += ultrasonicText;
    message += "|";
    message += currentRadioAge;
    message += "|";
    message += getLastValidIRText();
    message += "|";
    message += getLastValidUltrasonicText();
    message += "|";
    message += getLastValidMagneticText();
    message += "|";
    message += getRockType();

    sendText(client, message.c_str());
  }
  else if (requestLine.startsWith("GET /favicon.ico")) {
    sendNotFound(client);
  }
  else {
    sendNotFound(client);
  }
}

// ---------------- SETUP ----------------

void setup() {
  pinMode(RIGHT_DIR, OUTPUT);
  pinMode(RIGHT_EN, OUTPUT);
  pinMode(LEFT_DIR, OUTPUT);
  pinMode(LEFT_EN, OUTPUT);

  pinMode(IR_INPUT_PIN, INPUT);
  attachInterrupt(digitalPinToInterrupt(IR_INPUT_PIN), pulseISR, RISING);

  pinMode(ULTRASONIC_INPUT_PIN, INPUT);

  pinMode(RADIO_INPUT_PIN, INPUT_PULLUP);

  stopMotors();

  Serial.begin(9600);

  while (!Serial && millis() < 10000);

  Serial.println(F("\nStarting EEE Rover Web Server"));

  Wire.begin();

  Serial.println(F("Attempting BMM150 connection"));

  if (bmm150.begin()) {
    bmmReady = false;
    Serial.println(F("BMM150 init failed"));
    Serial.println(F("Magnetic sensor: NO READING"));
  }
  else {
    bmmReady = true;
    Serial.println(F("BMM150 init success"));
    Serial.println(F("Magnetic sensor: READY"));

    bmm150.setOperationMode(BMM150_POWERMODE_NORMAL);
    delay(50);
    bmm150.setPresetMode(BMM150_PRESETMODE_HIGHACCURACY);
    bmm150.setRate(BMM150_DATA_RATE_10HZ);
    bmm150.setMeasurementXYZ();
  }

  if (WiFi.status() == WL_NO_SHIELD) {
    Serial.println(F("WiFi shield not present"));
    while (true);
  }

  if (groupNumber) {
    WiFi.config(IPAddress(192, 168, 0, groupNumber + 1));
  }

  Serial.print(F("Connecting to WPA SSID: "));
  Serial.println(ssid);

  while (WiFi.begin(ssid, pass) != WL_CONNECTED) {
    delay(500);
    Serial.print('.');
  }

  Serial.println();
  Serial.println(F("WiFi connected"));

  server.begin();

  IPAddress ip = WiFi.localIP();

  Serial.print(F("HTTP server started @ "));
  Serial.print(ip[0]);
  Serial.print(F("."));
  Serial.print(ip[1]);
  Serial.print(F("."));
  Serial.print(ip[2]);
  Serial.print(F("."));
  Serial.println(ip[3]);
}

// ---------------- LOOP ----------------

void loop() {
  updateIRPulseRate();
  updateUltrasonicSensor();
  updateRadioSensor();

  if (motorsAreRunning && (millis() - lastMotorCommandTime > MOTOR_TIMEOUT_MS)) {
    stopMotors();
  }

  WiFiClient client = server.available();

  if (client) {
    unsigned long timeout = millis() + 1000;

    while (client.connected() && !client.available() && millis() < timeout) {
      delay(1);
    }

    if (client.available()) {
      String requestLine = client.readStringUntil('\r');
      client.readStringUntil('\n');

      while (client.available()) {
        String headerLine = client.readStringUntil('\n');
        if (headerLine == "\r" || headerLine.length() <= 1) {
          break;
        }
      }

      handleRequest(requestLine, client);
    }

    delay(1);
    client.stop();
  }
}
