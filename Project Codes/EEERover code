// ---------------- INFRARED SENSOR ----------------

const int IR_INPUT_PIN = 1;

volatile unsigned long pulseCount = 0;
unsigned long irPulseRate = 0;
unsigned long lastIRSampleTime = 0;

const unsigned long IR_TOLERANCE = 90;

int lastValidIRApprox = 0;

void pulseISR() {
  pulseCount++;
}

void updateLastValidIR() {
  if (irPulseRate >= 547 - IR_TOLERANCE && irPulseRate <= 547 + IR_TOLERANCE) {
    lastValidIRApprox = 547;
  }
  else if (irPulseRate >= 312 - IR_TOLERANCE && irPulseRate <= 312 + IR_TOLERANCE) {
    lastValidIRApprox = 312;
  }
}

String getLastValidIRText() {
  if (lastValidIRApprox == 547) {
    return "547 pulses/sec";
  }
  else if (lastValidIRApprox == 312) {
    return "312 pulses/sec";
  }

  return "NO READING";
}

void updateIRPulseRate() {
  if (millis() - lastIRSampleTime >= 1000) {
    noInterrupts();
    unsigned long count = pulseCount;
    pulseCount = 0;
    interrupts();

    irPulseRate = count;
    updateLastValidIR();
    lastIRSampleTime = millis();
  }
}

// ---------------- ULTRASONIC SENSOR ----------------

const int ULTRASONIC_INPUT_PIN = A0;

bool ultrasonicDetected = false;
bool HasUltraSound = false;

void updateUltrasonicSensor() {
  ultrasonicDetected = (digitalRead(ULTRASONIC_INPUT_PIN) == HIGH);
  HasUltraSound = ultrasonicDetected;
}

String getLastValidUltrasonicText() {
  if (HasUltraSound) {
    return "40kHz DETECTED";
  }

  return "NO 40kHz";
}

// ---------------- RADIO SENSOR ----------------

const int RADIO_INPUT_PIN = 13;
const unsigned int RADIO_BAUD_DELAY_US = 1667;
const unsigned long RADIO_TIMEOUT_MS = 2000;

String radioBuffer = "";
String currentRadioAge = "NO READING";

unsigned long lastRadioDataTime = 0;
bool radioTimedOut = false;

int readRadioByte() {
  if (digitalRead(RADIO_INPUT_PIN) == HIGH) {
    return -1;
  }

  delayMicroseconds(RADIO_BAUD_DELAY_US / 2);

  if (digitalRead(RADIO_INPUT_PIN) == HIGH) {
    return -1;
  }

  byte value = 0;

  for (int bitIndex = 0; bitIndex < 8; bitIndex++) {
    delayMicroseconds(RADIO_BAUD_DELAY_US);

    if (digitalRead(RADIO_INPUT_PIN) == HIGH) {
      value |= (1 << bitIndex);
    }
  }

  delayMicroseconds(RADIO_BAUD_DELAY_US);

  return value;
}

void processRadioChar(char data) {
  lastRadioDataTime = millis();
  radioTimedOut = false;

  if (data == '#') {
    if (radioBuffer.length() == 3) {
      currentRadioAge = radioBuffer.substring(0, 1) + "." + radioBuffer.substring(1, 3) + " billion years";
}
 }

    radioBuffer = "";
  if (isDigit(data)) {
    if (radioBuffer.length() < 3) {
      radioBuffer += data;
    }
    else {
      radioBuffer = "";
      radioBuffer += data;
    }
  }
}

void updateRadioSensor() {
  int incomingByte = readRadioByte();
  if (incomingByte >= 0) {
    processRadioChar((char)incomingByte);
  }

  if ((millis() - lastRadioDataTime > RADIO_TIMEOUT_MS) && !radioTimedOut) {
    radioBuffer = "";
    currentRadioAge = "NO READING";
    radioTimedOut = true;
  }
}

