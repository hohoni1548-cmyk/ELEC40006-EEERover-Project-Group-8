// ---------------- SPEED HELPER FUNCTIONS ----------------

int getFullSpeed() {
  if (speedMode == 0) {
    return 128;
  }
  else if (speedMode == 1) {
    return 192;
  }

  return 255;
}

int getHalfSpeed() {
  if (speedMode == 0) {
    return 64;
  }
  else if (speedMode == 1) {
    return 96;
  }

  return 128;
}

// ---------------- COMMAND SEQUENCE HELPERS ----------------

unsigned long getCommandSeq(String requestLine) {
  int seqIndex = requestLine.indexOf("seq=");

  if (seqIndex < 0) {
    return latestCommandSeq + 1;
  }

  int startIndex = seqIndex + 4;
  unsigned long seq = 0;

  while (startIndex < requestLine.length()) {
    char c = requestLine.charAt(startIndex);

    if (c < '0' || c > '9') {
      break;
    }

    seq = (seq * 10) + (c - '0');
    startIndex++;
  }

  return seq;
}

bool acceptMovementCommand(String requestLine) {
  unsigned long incomingSeq = getCommandSeq(requestLine);
  if (incomingSeq < latestCommandSeq) {
    return false;
  }

  latestCommandSeq = incomingSeq;
  return true;
}

bool acceptKeepAlive(String requestLine) {
  unsigned long incomingSeq = getCommandSeq(requestLine);
  if (incomingSeq == latestCommandSeq && motorsAreRunning) {
    return true;
  }

  return false;
}

// ---------------- MAGNETIC SENSOR HELPER ----------------

sBmm150MagData_t getMagneticData() {
  sBmm150MagData_t magData;
  magData.x = 0;
  magData.y = 0;
  magData.z = 0;

  if (bmmReady) {
    magData = bmm150.getGeomagneticData();
  }

  return magData;
}

String getMagneticDirection(float zValue) {
  if (!bmmReady) {
    return "NO READING";
  }

  if (zValue > magneticBaselineZ + 15.0) {
    return "UP";
  }
  else if (zValue < magneticBaselineZ - 15.0) {
    return "DOWN";
  }

  return "NO READING";
}

void updateLastValidMagnetic(String direction) {
  if (direction == "UP" || direction == "DOWN") {
    lastValidMagneticDirection = direction;
  }
}

String getLastValidMagneticText() {
  return lastValidMagneticDirection;
}

String getRockType() {
  if (lastValidMagneticDirection == "DOWN") {
    if (lastValidIRApprox == 547 && HasUltraSound) return "Basaltoid";
    if (lastValidIRApprox == 312 && !HasUltraSound) return "Gravion";
  } 
  else if (lastValidMagneticDirection == "UP") {
    if (lastValidIRApprox == 312 && HasUltraSound) return "Regolix";
    if (lastValidIRApprox == 547 && !HasUltraSound) return "Lunarite";
  }
  return "UNKNOWN ROCK";
}

void calibrateMagneticBaseline() {
  if (bmmReady) {
    sBmm150MagData_t magData = bmm150.getGeomagneticData();
    magneticBaselineZ = magData.z;
  }
}

// ---------------- MOTOR CONTROL FUNCTIONS ----------------

void stopMotors() {
  analogWrite(RIGHT_EN, 0);
  analogWrite(LEFT_EN, 0);
  motorsAreRunning = false;
}

void markMotorCommand() {
  lastMotorCommandTime = millis();
  motorsAreRunning = true;
}

void refreshMotorTimeout() {
  if (motorsAreRunning) {
    lastMotorCommandTime = millis();
  }
}

void rightMotorForward(int speedValue) {
  digitalWrite(RIGHT_DIR, RIGHT_FORWARD_DIR);
  analogWrite(RIGHT_EN, speedValue);
}

void rightMotorBackward(int speedValue) {
  digitalWrite(RIGHT_DIR, RIGHT_BACKWARD_DIR);
  analogWrite(RIGHT_EN, speedValue);
}

void leftMotorForward(int speedValue) {
  digitalWrite(LEFT_DIR, LEFT_FORWARD_DIR);
  analogWrite(LEFT_EN, speedValue);
}

void leftMotorBackward(int speedValue) {
  digitalWrite(LEFT_DIR, LEFT_BACKWARD_DIR);
  analogWrite(LEFT_EN, speedValue);
}

// ---------------- MOVEMENT FUNCTIONS ----------------

void driveForward() {
  markMotorCommand();
  leftMotorBackward(getFullSpeed());
  rightMotorBackward(getFullSpeed());
}

void driveBackward() {
  markMotorCommand();
  leftMotorForward(getFullSpeed());
  rightMotorForward(getFullSpeed());
}

void driveLeft() {
  markMotorCommand();
  leftMotorBackward(TURN_HALF_SPEED);
  rightMotorForward(TURN_HALF_SPEED);
}

void driveRight() {
  markMotorCommand();
  leftMotorForward(TURN_HALF_SPEED);
  rightMotorBackward(TURN_HALF_SPEED);
}

void driveForwardLeft() {
  markMotorCommand();
  leftMotorBackward(getHalfSpeed());
  rightMotorBackward(getFullSpeed());
}

void driveForwardRight() {
  markMotorCommand();
  leftMotorBackward(getFullSpeed());
  rightMotorBackward(getHalfSpeed());
}

void driveBackLeft() {
  markMotorCommand();
  leftMotorForward(getHalfSpeed());
  rightMotorForward(getFullSpeed());
}

void driveBackRight() {
  markMotorCommand();
  leftMotorForward(getFullSpeed());
  rightMotorForward(getHalfSpeed());
}

// ---------------- HTTP RESPONSE FUNCTIONS ----------------

void sendText(WiFiClient &client, const char *text) {
  client.println(F("HTTP/1.1 200 OK"));
  client.println(F("Content-Type: text/plain; charset=utf-8"));
  client.println(F("Cache-Control: no-store"));
  client.println(F("Connection: close"));
  client.println();
  client.print(text);
}

void sendNotFound(WiFiClient &client) {
  client.println(F("HTTP/1.1 404 Not Found"));
  client.println(F("Content-Type: text/plain; charset=utf-8"));
  client.println(F("Cache-Control: no-store"));
  client.println(F("Connection: close"));
  client.println();
  client.print(F("404"));
}

void sendChunk(WiFiClient &client, const __FlashStringHelper *chunk) {
  client.print(chunk);
}

